generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id              String           @id @default(uuid())
  youtubeId       String           @unique
  title           String
  description     String?
  thumbnailUrl    String?
  publishedAt     DateTime
  transcript      String?
  summary         String?
  summaryData     String?
  difficultyLevel String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  favorites       Favorite?
  history         History?
  records         PracticeRecord[]
  quizzes         Quiz[]
  notes           VideoNote?
}

model Favorite {
  videoId   String   @id @unique
  createdAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id])
}

model History {
  videoId   String   @id @unique
  watchedAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id])
}

model CommonTip {
  id             String   @id @default(uuid())
  title          String
  content        String
  category       String
  difficulty     String?
  sourceVideoIds String
  createdAt      DateTime @default(now())
}

model PracticeRecord {
  id                 String   @id @default(uuid())
  gymName            String?
  date               DateTime @default(now())
  duration           Int?
  practiceMenuId     String?
  videoId            String?
  routes             String
  reflection         String?
  nextGoal           String?
  createdAt          DateTime @default(now())
  aiAdvice           String?
  recommendedVideoId String?
  video              Video?   @relation(fields: [videoId], references: [id])
}

model VideoNote {
  id        String   @id @default(uuid())
  videoId   String   @unique
  content   String
  updatedAt DateTime @updatedAt
  video     Video    @relation(fields: [videoId], references: [id])
}

model Quiz {
  id        String   @id @default(uuid())
  videoId   String
  question  String
  options   String
  answer    String
  createdAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id])
}

model PracticeMenu {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
}

model QASession {
  id        String   @id @default(uuid())
  question  String
  answer    String
  sources   String?
  createdAt DateTime @default(now())
}
